# Local Development Port
PORT=3000
JSON_BODY_LIMIT_BYTES=65536
CONTACT_BODY_MAX_BYTES=24576
CHAT_BODY_MAX_BYTES=32768

# Groq AI Key for Chatbot
GROQ_API_KEY=

# Comma-separated CORS allowlist (set to * only if absolutely required)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5500,http://127.0.0.1:5500,https://vikashsaravanann.github.io

# Rate limits
CONTACT_RATE_LIMIT_WINDOW_MS=900000
CONTACT_RATE_LIMIT_MAX=8
CHAT_RATE_LIMIT_WINDOW_MS=60000
CHAT_RATE_LIMIT_MAX=20

# Discord webhook URL (Optional)
DISCORD_WEBHOOK_URL=

# Telegram Bot configurations (Optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# SMTP Nodemailer Configurations (Optional)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
CONTACT_RECEIVER_EMAIL=vikash07052008@gmail.com

# Optional fallback switch
ENABLE_FORMSUBMIT_FALLBACK=true
